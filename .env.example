# PostgreSQL — Tencent Cloud instance (SSH into server and set this to internal URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/thenest"

# iron-session secret — generate: openssl rand -base64 32
SESSION_SECRET="replace-with-32-char-random-string"

# Admin PIN hash — generate: node -e "const b=require('bcryptjs');console.log(b.hashSync('576',12))"
ADMIN_PIN_HASH="run-the-command-above-and-paste-hash-here"
